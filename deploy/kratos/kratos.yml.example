version: v1.1.0

dsn: postgres://kratos:replace-me@127.0.0.1:5432/kratos?sslmode=disable

serve:
  public:
    base_url: https://sukoon.uz/ory/
    host: 127.0.0.1
    port: 4433
  admin:
    base_url: https://127.0.0.1:4434/
    host: 127.0.0.1
    port: 4434

selfservice:
  default_browser_return_url: https://sukoon.uz/
  allowed_return_urls:
    - https://sukoon.uz/
    - https://www.sukoon.uz/
    - https://127.0.0.1/
  methods:
    password:
      enabled: true
    oidc:
      enabled: true
      config:
        providers:
          - id: google
            provider: google
            client_id: replace-me
            client_secret: replace-me
            mapper_url: file:///etc/kratos/google.jsonnet
            scope:
              - openid
              - email
              - profile

          - id: github
            provider: github
            client_id: replace-me
            client_secret: replace-me
            mapper_url: file:///etc/kratos/github.jsonnet
            scope:
              - user:email

  flows:
    error:
      ui_url: https://sukoon.uz/login
    login:
      ui_url: https://sukoon.uz/login
      after:
        default_browser_return_url: https://sukoon.uz/
    registration:
      ui_url: https://sukoon.uz/registration
      after:
        password:
          hooks:
            - hook: session
        oidc:
          hooks:
            - hook: session
        default_browser_return_url: https://sukoon.uz/
    settings:
      ui_url: https://sukoon.uz/
    recovery:
      enabled: false
    verification:
      enabled: false

log:
  level: info

secrets:
  cookie:
    - replace-with-long-random-secret
  cipher:
    - replace-with-long-random-secret

identity:
  default_schema_id: default
  schemas:
    - id: default
      url: file:///etc/kratos/identity.schema.json
